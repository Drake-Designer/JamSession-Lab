# Environment variables — copy this file to .env and fill in your values.
# Never commit .env to version control.

# Django secret key — used for cryptographic signing (sessions, CSRF tokens,
# password reset links, etc.). Generate one with:
#   python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Never reuse a key that has ever been committed to version control.
SECRET_KEY=your_secret_key_here

# Debug mode — must be exactly "True" to enable. Defaults to False (safe for
# production). Local development: set DJANGO_DEBUG=True in your .env.
DJANGO_DEBUG=True

# Comma-separated hostnames Django will serve (no spaces required).
# Production example: jamsessionlab.ie,www.jamsessionlab.ie
# Local development:
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated CSRF trusted origins (must include the https:// scheme).
# Required in production behind HTTPS (Render, custom domain).
# Production example:
#   https://your-app.onrender.com,https://jamsessionlab.ie,https://www.jamsessionlab.ie
# Local development: leave empty (CSRF uses the request host on http://localhost).
DJANGO_CSRF_TRUSTED_ORIGINS=

# Cloudinary credentials
CLOUD_NAME=your_cloud_name_here
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# PostgreSQL connection string (Neon: dashboard -> project -> Connect).
# The project fails to start if this is not set.
DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/jamsession?sslmode=require

# Resend — transactional email (verification, contact form, etc.).
# Preferred on Render: set RESEND_API_KEY and use the HTTPS API.
# Domain jamsessionlab.ie must be verified in Resend (SPF/DKIM).
# Local without a key: set EMAIL_BACKEND to console to print emails in the terminal.
RESEND_API_KEY=re_xxxxxxxx
DEFAULT_FROM_EMAIL=JamSession Lab <staff@jamsessionlab.ie>
# Where contact-form messages are delivered (forward this address to your inbox).
CONTACT_EMAIL=staff@jamsessionlab.ie
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Public site origin (scheme + host, no trailing slash). Used for canonical URLs,
# Open Graph images, JSON-LD, and the Sitemap line in robots.txt.
# Prefer one canonical host (apex or www) and redirect the other at DNS/hosting.
SITE_URL=https://jamsessionlab.ie

# Optional: Google Search Console HTML-tag verification (content value only).
# From Search Console → Settings → Ownership verification → HTML tag.
# GOOGLE_SITE_VERIFICATION=your_verification_token_here

# Optional: X/Twitter @handle for twitter:site (include the @).
# SEO_TWITTER_HANDLE=@jamsessionlab

# WhatsApp community invite (shown after registration and in welcome emails).
# Use a private invite link from WhatsApp; never commit the real URL.
# Leave empty locally if you do not need the join button.
WHATSAPP_COMMUNITY_LINK=https://chat.whatsapp.com/your_invite_code_here
